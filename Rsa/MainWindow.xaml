<Window x:Class="Rsa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rsa"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Параметры (простые числа):" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBox x:Name="TxtP" Width="60" ToolTip="Число P" Margin="0,0,10,0" Text="61"/>
                <TextBox x:Name="TxtQ" Width="60" ToolTip="Число Q" Text="53"/>
                <Button Content="Генерировать ключи" Click="BtnGenerate_Click" Margin="15,0,0,0" Padding="10,2"/>
            </StackPanel>

            <TextBlock Text="Исходный текст:" FontWeight="Bold"/>
            <TextBox x:Name="InputText" Height="60" Margin="0,5,0,10" TextWrapping="Wrap" AcceptsReturn="True"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button Content="Зашифровать" Click="BtnEncrypt_Click" Width="120" Margin="0,0,10,0" Background="#E1F5FE"/>
                <Button Content="Расшифровать" Click="BtnDecrypt_Click" Width="120" Background="#E8F5E9"/>
            </StackPanel>

            <TextBlock Text="Результат:" FontWeight="Bold"/>
            <TextBox x:Name="OutputText" Height="100" Margin="0,5,0,0" IsReadOnly="True" TextWrapping="Wrap" Background="#FAFAFA"/>
        </StackPanel>
    </Grid>
</Window>
